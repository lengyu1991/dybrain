---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'dybrain - 个人知识平台',
};
---

<Layout metadata={metadata}>
  <Hero
    actions={[
      { variant: 'primary', text: '进入项目', href: 'https://github.com/lengyu1991', target: '_blank' }
    ]}
    image={{ src: 'https://images.unsplash.com/photo-1519389950473-47ba0277781c?auto=format&fit=crop&w=2070&q=80', alt: 'Hero Image' }}
  >
    <Fragment slot="title">
      欢迎来到 <span class="text-accent dark:text-white">dybrain</span>
    </Fragment>
    <Fragment slot="subtitle">
      这里是一个集文章、笔记、工具导航于一体的个人知识平台。
    </Fragment>
  </Hero>

  <Note title="核心理念" description="简洁至上、注重体验、持续更新" />

  <Features
    title="本站功能"
    items={[
      { title: '文章笔记', description: '记录思考，分享知识。', icon: 'tabler:notebook' },
      { title: '工具导航', description: '优质资源，一站直达。', icon: 'tabler:tools' },
      { title: '持续迭代', description: '量化策略与期权数据。', icon: 'tabler:bulb' }
    ]}
  />

  <CallToAction
    title="即刻收藏"
    subtitle="无论读文章还是找工具，这里都有你想要的。"
    actions={[{ variant: 'primary', text: '开始探索', href: '#' }]}
  />
</Layout>
