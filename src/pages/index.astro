import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Dybrain — 我的数字大脑与投资笔记',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <Hero
    actions={[
      {
        variant: 'primary',
        text: '查看投资笔记',
        href: '/blog',
        icon: 'tabler:book',
      },
      { text: '了解更多', href: '#features' },
    ]}
    image={{ src: '~/assets/images/hero-image.png', alt: 'Dybrain 首页图片' }}
  >
    <Fragment slot="title">
      欢迎来到 <span class="text-accent dark:text-white">Dybrain</span>
      <br />
      <span class="text-3xl">记录投资、技术与成长的数字大脑</span>
    </Fragment>

    <Fragment slot="subtitle">
      <span class="hidden sm:inline">
        这里是我分享 <span class="font-semibold">美股期权策略</span>、<span class="font-semibold">AI 编程实践</span> 以及个人知识管理的私人领地。</span
      >
      <span class="block mb-1 sm:hidden font-bold text-blue-600">Dybrain：思考，沉淀，进化。</span>
      致力于通过数据驱动投资，用 AI 加速学习。
    </Fragment>
  </Hero>

  <Note title="核心理念:" description="长期主义、数据驱动、持续进化" />

  <Features
    id="features"
    tagline="核心板块"
    title="你在这里能看到什么"
    subtitle="深度聚焦金融投资与前沿技术，打造结构化的知识体系。"
    items={[
      {
        title: '美股与期权实战',
        description:
          '分享 Sell Put、轮转策略（Wheel Strategy）以及美股大盘的技术面深度分析。',
        icon: 'tabler:trending-up',
      },
      {
        title: 'AI 与 Vibe Coding',
        description:
          '探索如何利用 Cursor、Trae 等 AI 工具快速构建金融数据扫描器和自动化脚本。',
        icon: 'tabler:cpu',
      },
      {
        title: '个人知识管理',
        description:
          '基于 Obsidian 和 Astro 构建的第二大脑，将碎片化信息转化为结构化知识。',
        icon: 'tabler:brain',
      },
      {
        title: '全球化金融工具',
        description:
          '涉及 Wise、Schwab 等海外金融工具的使用心得与入金指南。',
        icon: 'tabler:world',
      },
      {
        title: '数据监控与预警',
        description:
          "实时跟踪标普500、比特币以及核心持仓的波动情况。",
        icon: 'tabler:device-analytics',
      },
      {
        title: '开源与交流',
        description:
          '拥抱开源文化，分享网站搭建教程与代码，与同道中人共同进步。',
        icon: 'tabler:message-circle',
      },
    ]}
  />

  <Content
    isReversed
    tagline="投资笔记"
    title="逻辑支撑：用数据和理性投资"
    items={[
      {
        title: '量化模型支持',
        description:
          '利用 Python 脚本自动计算期权年化收益率，筛选高胜率机会。',
      },
      {
        title: '跨市场视野',
        description:
          '同时关注加密货币、美股与宏观经济指标，构建全方位的资产防御体系。',
      },
      {
        title: '极简体验',
        description:
          '网页端与手机端完美适配，随时随地查阅核心策略与历史数据。',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1519389950473-47ba0277781c?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: '投资分析图片',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">建立现代化的投资框架</h3>
      通过技术手段降低情绪干扰，把握确定性机会。
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <Steps
    title="如何快速上手我的投资策略？"
    items={[
      {
        title: '第一步：<span class="font-medium">建立基础认知</span>',
        description:
          "阅读我的基础教程，了解现金担保看跌期权（Cash-Secured Puts）的基本逻辑与风险。这是我们“收租”生涯的起点。",
        icon: 'tabler:package',
      },
      {
        title: '第二步：<span class="font-medium">配置工具链</span>',
        description:
          "工欲善其事，必先利其器。参考我的指南配置好 Schwab、Wise 以及 Python 自动化环境。",
        icon: 'tabler:letter-case',
      },
      {
        title: '第三步：<span class="font-medium">持续实盘复盘</span>',
        description:
          '在我的博客中查看最新的实盘记录，跟随市场波动不断调整参数，优化收益曲线。',
        icon: 'tabler:paint',
      },
      {
        title: '准备就绪！',
        icon: 'tabler:check',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1616198814651-e71f960c3180?ixlib=rb-4.0.3&auto=format&fit=crop&w=987&q=80',
      alt: '步骤图片',
    }}
  />

  <FAQs
    title="常见问题"
    subtitle="关于 Dybrain 和我的投资思路的一些快速解答。"
    tagline="FAQs"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: '为什么要建立这个网站？',
        description:
          "写作是最好的思考。通过把复杂的投资逻辑写出来，我能更清晰地审视自己的决策。同时也希望以此结识志同道合的朋友。",
      },
      {
        title: '这里的建议可以作为投资依据吗？',
        description:
          '绝对不可以。所有内容仅作为个人学习记录。投资有风险，入市需谨慎。你应该根据自己的风险承受能力做决策。',
      },
      {
        title: '网站是用什么搭建的？',
        description:
          "使用 Astro 5.0 + Tailwind CSS 搭建，托管在 Cloudflare Pages。如果你也感兴趣，可以参考我的搭建教程。",
      },
    ]}
  />

  <BlogLatestPosts
    title="最新发布"
    information={`在这里你可以找到我最近的思考。
                每一篇笔记都是我在投资路上的一个脚印，
                希望能给你带来一点点启发。
                `}
  />

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: '开始阅读',
        href: '/blog',
        icon: 'tabler:arrow-right',
      },
    ]}
  >
    <Fragment slot="title">
      订阅我的&nbsp;<br class="block sm:hidden" /><span class="sm:whitespace-nowrap">投资随笔</span>
    </Fragment>

    <Fragment slot="subtitle">
      不定期分享市场洞察与技术实践。<br class="hidden md:inline" />让我们在复利的道路上慢慢变富。
    </Fragment>
  </CallToAction>
</Layout>
如何让这段代码生效？
打开你的 GitHub，找到 src/pages/index.astro 文件。

点击右上角的 “小铅笔”图标 进行编辑。

删掉里面原来的所有内容（可以用 Ctrl+A 然后 Backspace）。

把上面我写给你的这一大段代码复制粘贴进去。

点击页面最下方的绿色按钮 “Commit changes”。

等 1 分钟，刷新你的网站。

瞧！你的网站首页现在不仅变成了中文，连内容都充满了“金融和技术”的高端质感。

接下来，你还想修改哪个页面？或者是想在某个板块加上你的二维码/社交链接？





Gemini 是一款 AI 工具，其回答未必正确无误。

